{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window (desktop only — broad fs is required for ACP stdio agents that read/write files in the working directory)",
  "windows": ["main"],
  "platforms": ["macOS", "linux", "windows"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "dialog:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "**" }]
    }
  ]
}
